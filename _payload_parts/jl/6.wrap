 <Chip\n                    label=\"LE only eye\"\n                    selected={onlyEye === \"LE on
ly eye\"}\n                    onClick={() => setOnlyEye(onlyEye === \"LE only eye\" ? null : \"LE o
nly eye\")}\n                    optional\n                  />\n                </div>\n           
