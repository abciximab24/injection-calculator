/next/no-img-element */}\n                    <img src={qrDataUrl} alt=\"2D barcode QR code\" classN
ame=\"qr-image\" />\n                    <pre className=\"barcode-text\">{barcodeText}</pre>\n      
              <button\n                      type=\"button\"\n                      className=\"seco
ndary-btn\"\n                      onClick={() => navigator.clipboard?.writeText(barcodeText)}\n    
                >\n                      Copy text\n                    </button>\n                 
 </div>\n                )}\n              </div>\n            </div>\n          </div>\n        )}\
n      </main>\n\n      <footer className=\"app-footer\">\n        Dates: type DDMM (year {YEAR_HINT
}) or full DDMMYYYY · Q-week adjusts by weeks from\n        today to recent injection\n      </foote
r>\n    </div>\n  );\n}\n","encoding":"utf-8"}
