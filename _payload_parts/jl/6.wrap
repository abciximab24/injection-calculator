)}\n                </header>\n                {!qrDataUrl && (\n                  <p className=\"te
xt-sm text-slate-500\">\n                    Complete required fields and press Enter to generate.\n
                  </p>\n                )}\n                {qrDataUrl && barcodeText && (\n        
