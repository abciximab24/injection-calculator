       ← Back to Stage 1\n                  </button>\n                </div>\n                <h2 c
lassName=\"panel-title\">Clinical options & barcode</h2>\n                <p className=\"panel-sub\"
>\n                  Next injection interval:{\" \"}\n                  <strong className=\"text-sla
te-800\">{nextInjectionWeeks} weeks</strong>\n                </p>\n              </header>\n\n     
         <DateField\n                label=\"Recent past / upcoming injection\"\n                val
ue={recentInjection}\n                active={activeField === \"recentInjection\"}\n                
digitBuffer={digitBuffer}\n                onSelect={() => {\n                  setActiveField(\"rec
entInjection\");\n                  setDigitBuffer(\"\");\n                }}\n              />\n\n 
             <section>\n                <h3 className=\"section-label\">\n                  Eye <spa
n className=\"req\">required · pick one</span>\n                </h3>\n                <div classNam
e=\"chip-row\">\n                  <Chip label=\"RE\" selected={eye === \"RE\"} onClick={() => setEy
e(\"RE\")} />\n                  <Chip label=\"LE\" selected={eye === \"LE\"} onClick={() => setEye(
\"LE\")} />\n                </div>\n              </section>\n\n              <section>\n          
      <h3 className=\"section-label\">\n                  Diagnosis <span className=\"req\">required
 · pick one</span>\n                </h3>\n                <div className=\"chip-row\">\n           
       <Chip label=\"wAMD\" selected={diagnosis === \"wAMD\"} onClick={() => setDiagnosis(\"wAMD\")}
 />\n                  <Chip label=\"PCV\" selected={diagnosis === \"PCV\"} onClick={() => setDiagno
sis(\"PCV\")} />\n                </div>\n              </section>\n\n              <section>\n     
           <h3 className=\"section-label\">\n                  Only eye <span className=\"opt\">opti
onal · pick one or none</span>\n                </h3>\n                <div className=\"chip-row\">\
n                  <Chip\n                    label=\"RE only eye\"\n                    selected={o
nlyEye === \"RE only eye\"}\n                    onClick={() => setOnlyEye(onlyEye === \"RE only eye
